# Cortex Memory System - Environment Variables

# ====================
# CORTEX API
# ====================

# Diretório de dados (padrão: ~/.cortex)
# CORTEX_DATA_DIR=/caminho/customizado

# Porta da API REST (padrão: 8000)
# CORTEX_API_PORT=8000

# Host da API REST (padrão: 127.0.0.1)
# CORTEX_API_HOST=127.0.0.1


# ====================
# OLLAMA
# ====================

# URL do Ollama (padrão: http://localhost:11434)
# OLLAMA_URL=http://localhost:11434

# Modelo Ollama padrão
# OLLAMA_MODEL=llama3.2:3b


# ====================
# DESENVOLVIMENTO
# ====================

# Modo debug
# DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
