# ============================================
# CORTEX MEMORY SYSTEM - CONFIGURAÇÃO
# ============================================
# Copie este arquivo para .env e ajuste conforme necessário
# As variáveis comentadas mostram os valores padrão

# ============================================
# API CORTEX
# ============================================

# URL completa da API Cortex
# Usado por: SDK, benchmark, workers
CORTEX_API_URL=http://localhost:8000

# Host onde a API escuta (0.0.0.0 = todas interfaces)
CORTEX_HOST=0.0.0.0

# Porta da API REST
CORTEX_PORT=8000

# Diretório para armazenamento de dados (grafos, checkpoints)
# Padrão: ./data (relativo ao projeto)
CORTEX_DATA_DIR=./data

# Namespace padrão para isolamento de memórias
# Cada agente/cliente pode ter seu próprio namespace
CORTEX_NAMESPACE=default

# Hot reload da API (apenas desenvolvimento)
# CORTEX_RELOAD=false

# ============================================
# OLLAMA / LLM
# ============================================

# URL do servidor Ollama
# WSL: Use o IP do Windows (ex: http://172.30.64.1:11434)
# Linux/Mac: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# Modelo padrão para inferência
# Opções testadas: gemma3:4b, qwen2.5:3b, ministral-3:3b
OLLAMA_MODEL=gemma3:4b

# Modelo de embedding para busca semântica
# Opções: qwen3-embedding:0.6b (recomendado), nomic-embed-text, all-minilm
# O modelo precisa estar instalado no Ollama
CORTEX_EMBEDDING_MODEL=qwen3-embedding:0.6b

# ============================================
# PERFORMANCE / LIMITES
# ============================================

# Janela de contexto (últimas N mensagens mantidas na sessão)
# CORTEX_CONTEXT_WINDOW=10

# Timeout para chamadas LLM (segundos)
# CORTEX_LLM_TIMEOUT=120

# Máximo de tentativas em caso de rate limit
# CORTEX_MAX_RETRIES=10

# ============================================
# DECAIMENTO (Ebbinghaus)
# ============================================
# Configurações do modelo de esquecimento

# Estabilidade base em dias (memórias duram ~7 dias sem reforço)
# CORTEX_DECAY_BASE_STABILITY=7.0

# Limiar de retrievability para considerar "esquecido"
# CORTEX_DECAY_FORGOTTEN_THRESHOLD=0.1

# Limiar para considerar "fraco"
# CORTEX_DECAY_WEAK_THRESHOLD=0.3

# Referências mínimas para ser considerado "hub" (memória importante)
# CORTEX_DECAY_HUB_THRESHOLD=5

# ============================================
# MEMÓRIA COMPARTILHADA
# ============================================
# Configurações para cenários multi-cliente

# Modo de operação:
# - single_user: Tudo é pessoal, sem compartilhamento
# - multi_client: Memória pessoal + conhecimento coletivo (sem PII)
# - team: Workspace compartilhado entre desenvolvedores
CORTEX_MEMORY_MODE=multi_client

# Quantos usuários diferentes precisam ter padrão similar
# para promover memória pessoal para conhecimento coletivo (LEARNED)
# CORTEX_PROMOTION_THRESHOLD=3

# ============================================
# REFINAMENTO DO SONO (SleepRefiner)
# ============================================
# Processo em background que consolida memórias

# Habilita o refinamento automático
CORTEX_SLEEP_ENABLED=true

# Consolida memórias pessoais de cada cliente
CORTEX_SLEEP_REFINE_PERSONAL=true

# Extrai padrões e cria conhecimento coletivo
CORTEX_SLEEP_REFINE_COLLECTIVE=true

# Filtro de PII/PCI para memória coletiva:
# - strict: Remove TUDO que pareça dado pessoal (recomendado)
# - moderate: Remove apenas dados sensíveis óbvios
# - none: Não filtra (PERIGOSO - não use em produção)
CORTEX_SLEEP_PII_FILTER=strict

# ============================================
# DESENVOLVIMENTO / DEBUG
# ============================================

# Modo debug (mais logs, stack traces)
# DEBUG=false

# Nível de log: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Desabilita telemetria do LiteLLM
LITELLM_TELEMETRY=False
